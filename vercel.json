{
  "buildCommand": "npm run build --prefix frontend && uv sync --prefix backend",
  "functions": {
    "api/**/*.py": {
      "runtime": "python@3.11"
    }
  },
  "experimentalServices": [
    {
      "name": "frontend",
      "root": "frontend",
      "runtime": "nodejs@20.x",
      "buildCommand": "npm run build",
      "outputDirectory": "dist"
    },
    {
      "name": "backend",
      "root": "backend",
      "runtime": "python@3.11",
      "buildCommand": "uv sync",
      "startCommand": "uv run uvicorn app.main:app --host 0.0.0.0 --port $PORT"
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
