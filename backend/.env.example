# === DEVELOPMENT (Local) ===
DATABASE_URL=sqlite:///./safemap.db
GEMINI_API_KEY=USE_YOUR_OWN_API_KEY
FRONTEND_URL=https://safemap-evorozon.vercel.app/

# === PRODUCTION (Vercel) ===
# REQUIRED:
#   GEMINI_API_KEY=your_actual_key_here
# 
# OPTIONAL (auto-handled by Vercel CORS regex):
#   FRONTEND_URL is not needed - backend already allows *.vercel.app
#   DATABASE_URL will use default SQLite (note: resets on each deploy)
#
# If using custom domain on Vercel, set:
#   FRONTEND_URL=https://your-custom-domain.com
